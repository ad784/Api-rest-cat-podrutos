# =============================================
# VARIÁVEIS DE AMBIENTE - API Catálogo de Produtos
# =============================================
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env no repositório!

# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- Banco de Dados ---
# Exemplo local:  mongodb://localhost:27017/catalogo_db
# Exemplo Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/catalogo_db
MONGO_URI=mongodb://localhost:27017/catalogo_db

# --- Autenticação JWT ---
# Use uma string longa, aleatória e secreta
JWT_SECRET=sua_chave_secreta_muito_segura_aqui
JWT_EXPIRES_IN=7d
